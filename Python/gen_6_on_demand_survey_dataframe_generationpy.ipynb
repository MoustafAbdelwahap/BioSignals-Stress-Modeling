import pandas as pd
import os
import json

import my_paths



# TODO change path to find survey_answer in MIAMS_Raw_Dataset instead of Downloads directory
def generate_on_demand_survey_dataframe() :
    """
    Reads the extract from the survey_answer table to extract responses to the on-demand surveys.
    Beware of timezones. We use a csv file with the hours in UTC to generate a parquet file in Paris time.
    
                                            attempt_nb  stress_score_at_this_moment                                            comment
    UUID Timestamp
    21   2022-02-14 14:25:35.858000+01:00           0                         60.0
    25   2022-02-15 08:08:00.325000+01:00           0                         70.0                   copine coincée dans l'ascenseur 
    34   2022-03-09 15:25:32.400000+01:00           1                         90.0
    31   2022-03-09 16:04:15.002000+01:00           2                         80.0                        Exposé UE6 TD Développement
    23   2022-02-18 07:02:05.621000+01:00           0                         70.0                  examen de psychopathologie à 10h 
    ...                                           ...                          ...                                                ...
    100  2022-05-10 20:11:27.120000+02:00           2                         70.0  cet après-midi et soirée : révisions intensive...
    112  2022-05-11 05:17:07.711000+02:00           2                         70.0                                          insomnie 
    105  2022-05-11 06:35:53.151000+02:00           3                         50.0            stress lié à des cauchemars cette nuit 
    127  2022-05-11 06:55:19.185000+02:00           1                         60.0
    120  2022-05-11 06:59:12.575000+02:00           2                         90.0
    """
    # read file containing all survey answers
    df = pd.read_csv(filepath_or_buffer=os.path.join(my_paths.downloads_directory_path, "survey_answer_202205161145.csv"))
    # keep only the lines about the on demand survey
    df = df.query("survey_id == 31")
    # eliminate debug lines
    df = df.query("user_id > 15")
    # drop survey_id and uuid columns
    df.drop(["uuid", "survey_id"], axis=1, inplace=True)
    # set user_id and answer_date columns as multi-index
    df.set_index(["user_id", "answer_date"], inplace=True, verify_integrity=True)    
    df.index = pd.MultiIndex.from_arrays([df.index.get_level_values(0), pd.to_datetime(df.index.get_level_values(1))], names=["UUID", "Timestamp"])
    # transform answer column into "stress_score_at_this_moment" and "comment"
    df = df.reindex(columns=df.columns.to_list()+["stress_score_at_this_moment", "comment"])
    for idx in df.index :
        answer_data = json.loads(json.loads(df.loc[idx]["answer"])["data"][0])["data"]
        df.loc[idx, "stress_score_at_this_moment"] = int(float(answer_data[0]["data"]))
        df.loc[idx, "comment"] = answer_data[1]["data"]
    df.drop("answer", axis=1, inplace=True)
    # convert UTC Date into Paris date
    df.index = pd.MultiIndex.from_arrays([df.index.get_level_values(0), df.index.get_level_values(1).tz_localize("UTC").tz_convert('Europe/Paris')])
    # write parquet file in the destination folder
    df.to_parquet(
        path=my_paths.on_demand_survey_dataframe_path,
        compression='gzip'
    )
